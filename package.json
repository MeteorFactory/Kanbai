{
  "name": "kanbai",
  "version": "1.0.0",
  "description": "Kanbai - Environnement de developpement avec Claude AI",
  "main": "dist/main/index.js",
  "author": "Antony Kervazo Canut",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:companion": "KANBAI_DEV_CODE=KANBAI vite",
    "build": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "build:app": "npm run build && electron-builder --mac",
    "build:app:win": "npm run build && electron-builder --win",
    "build:local": "npm run build && electron-builder --mac --publish never",
    "build:local:win": "npm run build && electron-builder --win --publish never",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "pixel-agents:setup": "bash scripts/setup-pixel-agents.sh",
    "pixel-agents:update": "cd vendor/pixel-agents && git pull && cd webview-ui && npm install && npm run build && cd ../../.. && node scripts/patch-pixel-agents-html.js",
    "rtk:setup": "bash scripts/setup-rtk.sh",
    "rtk:setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-rtk-windows.ps1",
    "rtk:update": "cd vendor/rtk && git pull"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@monaco-editor/react": "4.7.0",
    "better-sqlite3": "12.6.2",
    "electron-store": "11.0.2",
    "electron-updater": "6.8.3",
    "ignore": "7.0.5",
    "monaco-editor": "0.55.1",
    "mongodb": "7.1.0",
    "mssql": "12.2.0",
    "mysql2": "3.18.2",
    "node-pty": "1.1.0",
    "pdfjs-dist": "5.5.207",
    "pg": "8.19.0",
    "pngjs": "7.0.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/mssql": "9.1.9",
    "@types/node": "25.3.2",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "concurrently": "9.2.1",
    "electron": "40.6.1",
    "electron-builder": "26.8.1",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "jsdom": "29.0.1",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-electron": "0.29.0",
    "vite-plugin-electron-renderer": "0.14.6",
    "vitest": "4.0.18",
    "zustand": "5.0.11"
  },
  "overrides": {
    "eslint": {
      "minimatch": "3.1.5"
    },
    "@eslint/config-array": {
      "minimatch": "3.1.5"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.5"
    },
    "eslint-plugin-react": {
      "minimatch": "3.1.5"
    },
    "@electron/asar": {
      "minimatch": "3.1.5"
    },
    "dir-compare": {
      "minimatch": "3.1.5"
    },
    "glob": {
      "minimatch": "9.0.9"
    },
    "@electron/universal": {
      "minimatch": "9.0.9"
    },
    "cacache": {
      "minimatch": "9.0.9"
    },
    "test-exclude": {
      "minimatch": "9.0.9"
    }
  },
  "build": {
    "appId": "com.akc.kanbai",
    "productName": "Kanbai",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "strictVerify": true
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "differentialPackage": true
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/better-sqlite3/**",
      "dist/mcp-server/**"
    ],
    "extraResources": [
      {
        "from": "src/main/assets/rule-templates",
        "to": "rule-templates",
        "filter": [
          "**/*.md"
        ]
      },
      {
        "from": "vendor/pixel-agents/dist/webview",
        "to": "pixel-agents",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": true,
    "publish": {
      "provider": "github",
      "owner": "AntonyCanut",
      "repo": "Kanbai"
    }
  }
}
